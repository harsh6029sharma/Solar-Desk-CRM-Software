generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  FACEBOOK
  GOOGLE_ADS
  REFERRAL
  WALK_IN
  PHONE_CALL
}

model Organization {
  id String @id @default(cuid())

  name      String
  legalName String?

  email String? @unique
  phone String?

  website String?

  gstNumber String? @unique
  panNumber String? @unique

  logoUrl String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[] // employees
  contacts        Contact[]
  products        Product[]
  categories      Category[]
  manufacturers   Manufacturer[]
  addresses       Address[]
  leads           Lead[]
  opportunities   Opportunity[]
  tasks           Task[]
  quotations      Quotation[]
  installations   Installation[]
  warranties      Warranty[]
  amcs            Amc[]
  serviceRequests ServiceRequest[]
}

model User {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  firstName String
  lastName  String?

  email String  @unique
  phone String? @unique

  password String

  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles                 UserRole[]
  assignedInstallations Installation[]

  assignedLeads           Lead[]
  assignedOpportunities   Opportunity[]
  assignedTasks           Task[]
  assignedServiceRequests ServiceRequest[]
}

model Role {
  id String @id @default(cuid())

  name        String  @unique
  description String?

  isSystem Boolean @default(true)

  users           UserRole[]
  rolePermissions RolePermission[]
}

// join table of User and Role because User and Role has many to many relationship
model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Permission {
  id String @id @default(cuid())

  name        String  @unique
  description String?

  isSystem Boolean @default(true)

  roles RolePermission[]
}

// join table of role and permission
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Contact {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  firstName String
  lastName  String?
  phone     String
  email     String?
  isActive  Boolean @default(true)

  addresses     Address[]
  leads         Lead[]
  installations Installation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A single org cannot have duplicate email/phone, but different orgs can
  @@unique([organizationId, phone])
  @@unique([organizationId, email])
}

model Address {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  line1     String?
  line2     String?
  country   String?
  city      String
  state     String
  pincode   String
  isPrimary Boolean @default(false)

  installations Installation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

model Category {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  description String?

  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Manufacturer {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name String

  email   String?
  phone   String?
  website String?

  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Product {
  id String @id @default(cuid())

  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  categoryId String // Solar Panel, Inverter, Battery, EV Charger
  category   Category @relation(fields: [categoryId], references: [id])

  manufacturerId String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])

  sku String @unique // sku=stock keeping unit  Unique product code 

  capacity String // 5KW, 10KW

  basePrice Decimal? @db.Decimal(12, 2) // basePrice is dynamic current market price that changes after some duration

  description String?

  isActive Boolean @default(true)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  leadProducts   LeadProduct[]
  quotationItems QuotationItem[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([manufacturerId])
}

model Lead {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  source LeadSource

  status LeadStatus @default(NEW)

  budget Decimal? @db.Decimal(12, 2)

  expectedInstallation DateTime?

  assignedTo String
  user       User   @relation(fields: [assignedTo], references: [id])

  isActive Boolean @default(true)

  leadProducts LeadProduct[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  opportunity Opportunity?

  @@index([organizationId])
  @@index([contactId])
  @@index([assignedTo])
  @@index([status])
}

model LeadProduct {
  leadId    String
  productId String

  quantity Int @default(1)

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([leadId, productId])
  @@index([productId])
  @@index([leadId])
}

enum OpportunityStage {
  QUALIFICATION
  SITE_SURVEY
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model Opportunity {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id])

  assignedTo   String
  assignedUser User   @relation(fields: [assignedTo], references: [id])

  stage OpportunityStage @default(QUALIFICATION)

  expectedRevenue Decimal? @db.Decimal(12, 2)

  probability Int?

  expectedCloseDate DateTime?

  lostReason String?

  remarks String?

  isActive Boolean @default(true)

  quotations Quotation[]
  siteSurvey SiteSurvey?

  tasks        Task[]
  installation Installation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([assignedTo])
  @@index([stage])
}

model SiteSurvey {
  id            String      @id @default(cuid())
  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  // Solar Specific Technical Details
  roofType           String? // RCC slab, Tin shade, Asbestos sheet
  roofAreaSqFt       Decimal? @db.Decimal(10, 2)
  sanctionedLoadKw   Decimal? @db.Decimal(10, 2)
  monthlyBillAverage Decimal? @db.Decimal(12, 2)
  shadowAnalysis     String? // Notes on shadow issues
  latitude           Float?
  longitude          Float?
  surveyPhotosUrl    String[] @default([]) // Array for roof images

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])

  assignedTo   String
  assignedUser User   @relation(fields: [assignedTo], references: [id])

  title String

  description String?

  priority TaskPriority @default(MEDIUM)

  status TaskStatus @default(PENDING)

  dueDate DateTime?

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([assignedTo])
  @@index([opportunityId])
  @@index([status])
  @@index([dueDate])
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model Quotation {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])

  quotationNumber String @unique

  status QuotationStatus @default(DRAFT)

  totalAmount Decimal @db.Decimal(12, 2)

  validTill DateTime?

  items        QuotationItem[]
  installation Installation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([opportunityId])
  @@index([organizationId])
}

model QuotationItem {
  id String @id @default(cuid())

  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  productId String

  product Product @relation(fields: [productId], references: [id])

  quantity Int

  unitPriceSnapshot   Decimal @db.Decimal(12, 2)
  productNameSnapshot String

  totalPrice Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quotationId])
  @@index([productId])
}

enum InstallationStatus {
  SCHEDULED

  IN_PROGRESS

  COMPLETED

  CANCELLED
}

model Installation {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  installationNumber String @unique

  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])

  quotationId String    @unique
  quotation   Quotation @relation(fields: [quotationId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  amcs            Amc[]
  serviceRequests ServiceRequest[]

  status InstallationStatus @default(SCHEDULED)

  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  remarks String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  warranty  Warranty?

  @@index([organizationId])
  @@index([assignedToId])
  @@index([contactId])
  @@index([status])
  @@index([scheduledDate])
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOID
}

model Warranty {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  installationId String       @unique
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  warrantyNumber String @unique

  startDate DateTime
  endDate   DateTime

  status WarrantyStatus @default(ACTIVE)

  terms String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum AmcStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AmcFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

model Amc {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  installationId String
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  amcNumber String @unique

  startDate DateTime
  endDate   DateTime

  amount Decimal @db.Decimal(12, 2)

  frequency AmcFrequency

  status AmcStatus @default(ACTIVE)

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([installationId])
  @@index([status])
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ServiceRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model ServiceRequest {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  installationId String
  installation   Installation @relation(fields: [installationId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  ticketNumber String @unique

  title String

  description String?

  priority ServiceRequestPriority @default(MEDIUM)

  status ServiceRequestStatus @default(OPEN)

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([installationId])
  @@index([assignedToId])
  @@index([status])
}
